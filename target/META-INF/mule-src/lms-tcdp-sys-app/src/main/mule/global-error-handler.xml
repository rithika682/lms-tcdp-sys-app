<?xml version="1.0" encoding="UTF-8"?>
 
<mule xmlns:cluster="http://www.mulesoft.org/schema/mule/ee/cluster"
	xmlns:ee="http://www.mulesoft.org/schema/mule/ee/core" xmlns="http://www.mulesoft.org/schema/mule/core"
	xmlns:doc="http://www.mulesoft.org/schema/mule/documentation"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="
http://www.mulesoft.org/schema/mule/ee/core http://www.mulesoft.org/schema/mule/ee/core/current/mule-ee.xsd http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd">
 
	<!-- ============================================================ -->
	<!--              GLOBAL ERROR HANDLER                            -->
	<!--  DB errors → proper HTTP status + structured JSON response   -->
	<!--  All errors propagate up to Process API via HTTP response    -->
	<!-- ============================================================ -->
 
	<error-handler name="lms-tcdp-sapi-global-error-handler" doc:name="Global Error Handler" doc:id="a39c54d1-e09f-40a9-a5c9-db5ccd30dbae">
 
		<!-- ============================================================ -->
		<!-- DB:CONNECTIVITY → 503 Service Unavailable                    -->
		<!-- Happens when: too many clients, DB server down, network fail  -->
		<!-- ============================================================ -->
		 <on-error-propagate type="DB:CONNECTIVITY">
            <logger level="ERROR" message='#["DB:CONNECTIVITY - " ++ error.description]'/>
            <ee:transform doc:name="Error Response">
                <ee:message>
                    <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
    status       : "error",
    errorType    : error.errorType.identifier,
    errorMessage : "Database connection failed",
    transactionId: correlationId,
    timeStamp    : now() as DateTime
}]]></ee:set-payload>
                </ee:message>
                <ee:variables>
                    <ee:set-variable variableName="httpStatus">503</ee:set-variable>
                </ee:variables>
            </ee:transform>
        </on-error-propagate>

        <!-- DB Query Execution -->
        <on-error-propagate type="DB:QUERY_EXECUTION">
            <logger level="ERROR" message='#["DB:QUERY_EXECUTION - " ++ error.description]'/>
            <ee:transform doc:name="Error Response">
                <ee:message>
                    <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
    status       : "error",
    errorType    : error.errorType.identifier,
    errorMessage : "Query execution failed",
    transactionId: correlationId,
    timeStamp    : now() as DateTime
}]]></ee:set-payload>
                </ee:message>
                <ee:variables>
                    <ee:set-variable variableName="httpStatus">400</ee:set-variable>
                </ee:variables>
            </ee:transform>
        </on-error-propagate>

        <!-- DB Bad SQL Syntax -->
        <on-error-propagate type="DB:BAD_SQL_SYNTAX">
            <logger level="ERROR" message='#["DB:BAD_SQL_SYNTAX - " ++ error.description]'/>
            <ee:transform doc:name="Error Response">
                <ee:message>
                    <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
    status       : "error",
    errorType    : error.errorType.identifier,
    errorMessage : "Invalid SQL syntax",
    transactionId: correlationId,
    timeStamp    : now() as DateTime
}]]></ee:set-payload>
                </ee:message>
                <ee:variables>
                    <ee:set-variable variableName="httpStatus">400</ee:set-variable>
                </ee:variables>
            </ee:transform>
        </on-error-propagate>

        <!-- DB Retry Exhausted -->
        <on-error-propagate type="DB:RETRY_EXHAUSTED">
            <logger level="ERROR" message='#["DB:RETRY_EXHAUSTED - " ++ error.description]'/>
            <ee:transform doc:name="Error Response">
                <ee:message>
                    <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
    status       : "error",
    errorType    : error.errorType.identifier,
    errorMessage : "Database operation failed after maximum retries",
    transactionId: correlationId,
    timeStamp    : now() as DateTime
}]]></ee:set-payload>
                </ee:message>
                <ee:variables>
                    <ee:set-variable variableName="httpStatus">503</ee:set-variable>
                </ee:variables>
            </ee:transform>
        </on-error-propagate>

        <!-- HTTP Connectivity -->
        <on-error-propagate type="HTTP:CONNECTIVITY">
            <logger level="ERROR" message='#["HTTP:CONNECTIVITY - " ++ error.description]'/>
            <ee:transform doc:name="Error Response">
                <ee:message>
                    <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
    status       : "error",
    errorType    : error.errorType.identifier,
    errorMessage : "External service unavailable",
    transactionId: correlationId,
    timeStamp    : now() as DateTime
}]]></ee:set-payload>
                </ee:message>
                <ee:variables>
                    <ee:set-variable variableName="httpStatus">503</ee:set-variable>
                </ee:variables>
            </ee:transform>
        </on-error-propagate>

        <!-- HTTP Timeout -->
        <on-error-propagate type="HTTP:TIMEOUT">
            <logger level="ERROR" message='#["HTTP:TIMEOUT - " ++ error.description]'/>
            <ee:transform doc:name="Error Response">
                <ee:message>
                    <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
    status       : "error",
    errorType    : error.errorType.identifier,
    errorMessage : "Request timeout",
    transactionId: correlationId,
    timeStamp    : now() as DateTime
}]]></ee:set-payload>
                </ee:message>
                <ee:variables>
                    <ee:set-variable variableName="httpStatus">504</ee:set-variable>
                </ee:variables>
            </ee:transform>
        </on-error-propagate>

        <!-- HTTP Client Errors -->
        <on-error-propagate type="HTTP:BAD_REQUEST,HTTP:UNAUTHORIZED,HTTP:FORBIDDEN,HTTP:NOT_FOUND">
            <logger level="ERROR" message='#["HTTP:CLIENT_ERROR - " ++ error.description]'/>
            <ee:transform doc:name="Error Response">
                <ee:message>
                    <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
    status       : "error",
    errorType    : error.errorType.identifier,
    errorMessage : error.description,
    transactionId: correlationId,
    timeStamp    : now() as DateTime
}]]></ee:set-payload>
                </ee:message>
                <ee:variables>
                    <ee:set-variable variableName="httpStatus">400</ee:set-variable>
                </ee:variables>
            </ee:transform>
        </on-error-propagate>

        <!-- Expression Error -->
        <on-error-propagate type="EXPRESSION">
            <logger level="ERROR" message='#["EXPRESSION - " ++ error.description]'/>
            <ee:transform doc:name="Error Response">
                <ee:message>
                    <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
    status       : "error",
    errorType    : error.errorType.identifier,
    errorMessage : "Data processing error",
    transactionId: correlationId,
    timeStamp    : now() as DateTime
}]]></ee:set-payload>
                </ee:message>
                <ee:variables>
                    <ee:set-variable variableName="httpStatus">400</ee:set-variable>
                </ee:variables>
            </ee:transform>
        </on-error-propagate>

        <!-- Transformation Error -->
        <on-error-propagate type="TRANSFORMATION">
            <logger level="ERROR" message='#["TRANSFORMATION - " ++ error.description]'/>
            <ee:transform doc:name="Error Response">
                <ee:message>
                    <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
    status       : "error",
    errorType    : error.errorType.identifier,
    errorMessage : "Data transformation failed",
    transactionId: correlationId,
    timeStamp    : now() as DateTime
}]]></ee:set-payload>
                </ee:message>
                <ee:variables>
                    <ee:set-variable variableName="httpStatus">400</ee:set-variable>
                </ee:variables>
            </ee:transform>
        </on-error-propagate>

        <!-- APIkit Errors -->
        <on-error-propagate type="APIKIT:BAD_REQUEST,APIKIT:NOT_FOUND,APIKIT:METHOD_NOT_ALLOWED,APIKIT:NOT_ACCEPTABLE,APIKIT:UNSUPPORTED_MEDIA_TYPE,APIKIT:NOT_IMPLEMENTED">
            <logger level="ERROR" message='#["APIKIT:" ++ error.errorType.identifier ++ " - " ++ error.description]'/>
            <ee:transform doc:name="Error Response">
                <ee:message>
                    <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
    status       : "error",
    errorType    : error.errorType.identifier,
    errorMessage : error.description,
    transactionId: correlationId,
    timeStamp    : now() as DateTime
}]]></ee:set-payload>
                </ee:message>
                <ee:variables>
                    <ee:set-variable variableName="httpStatus">error.attributes.statusCode default 400</ee:set-variable>
                </ee:variables>
            </ee:transform>
        </on-error-propagate>

        <!-- Generic Catch-All -->
        <on-error-propagate type="ANY">
            <logger level="ERROR" message='#["ANY:" ++ error.errorType.identifier ++ " - " ++ error.description]'/>
            <ee:transform doc:name="Error Response">
                <ee:message>
                    <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
    status       : "error",
    errorType    : error.errorType.identifier,
    errorMessage : "Internal server error",
    transactionId: correlationId,
    timeStamp    : now() as DateTime
}]]></ee:set-payload>
                </ee:message>
                <ee:variables>
                    <ee:set-variable variableName="httpStatus">500</ee:set-variable>
                </ee:variables>
            </ee:transform>
        </on-error-propagate>

    </error-handler>
 
</mule>
