,"value":17},"CLOSING_TAG_END_COLUMN":{"type":"java.lang.Integer","value":139},"OPENING_TAG_END_LINE":{"type":"java.lang.Integer","value":98},"OPENING_TAG_START_LINE":{"type":"java.lang.Integer","value":98},"CLOSING_TAG_START_LINE":{"type":"java.lang.Integer","value":98},"CLOSING_TAG_START_COLUMN":{"type":"java.lang.Integer","value":17},"OPENING_TAG_END_COLUMN":{"type":"java.lang.Integer","value":139},"CLOSING_TAG_END_LINE":{"type":"java.lang.Integer","value":98},"IS_SELF_CLOSING":{"type":"java.lang.Boolean","value":true}},"sourceCode":"\u003cflow-ref doc:name\u003d\"Flow Reference to Common Flow\" doc:id\u003d\"cd5b9667-fcc8-4425-94ca-8ed4503433bb\" name\u003d\"common-sub-flow\"\u003e\u003c/flow-ref\u003e","startColumn":17,"startLine":98},"groupModelName":"General","modelName":"name","value":{"aString":"common-sub-flow"},"defaultValue":false},{"groupModelName":"Output","modelName":"target","value":{},"defaultValue":true},{"unresolvedValue":"#[payload]","metadata":{"docAttributes":{"name":"Flow Reference to Common Flow","id":"cd5b9667-fcc8-4425-94ca-8ed4503433bb"},"endColumn":139,"endLine":98,"fileName":"implementation/lms-tcdp-fetch-data-api.xml","fileUri":"file:/C:/Users/Rithika/AnypointStudio/GMMCO/lms-tcdp-sys-app-1.0.1-mule-application/src/main/mule/implementation/lms-tcdp-fetch-data-api.xml","importLocationChain":[],"parserAttributes":{"OPENING_TAG_START_COLUMN":{"type":"java.lang.Integer","value":17},"CLOSING_TAG_END_COLUMN":{"type":"java.lang.Integer","value":139},"OPENING_TAG_END_LINE":{"type":"java.lang.Integer","value":98},"OPENING_TAG_START_LINE":{"type":"java.lang.Integer","value":98},"CLOSING_TAG_START_LINE":{"type":"java.lang.Integer","value":98},"CLOSING_TAG_START_COLUMN":{"type":"java.lang.Integer","value":17},"OPENING_TAG_END_COLUMN":{"type":"java.lang.Integer","value":139},"CLOSING_TAG_END_LINE":{"type":"java.lang.Integer","value":98},"IS_SELF_CLOSING":{"type":"java.lang.Boolean","value":true}},"sourceCode":"\u003cflow-ref doc:name\u003d\"Flow Reference to Common Flow\" doc:id\u003d\"cd5b9667-fcc8-4425-94ca-8ed4503433bb\" name\u003d\"common-sub-flow\"\u003e\u003c/flow-ref\u003e","startColumn":17,"startLine":98},"groupModelName":"Output","modelName":"targetValue","value":{"expression":"payload"},"defaultValue":true}],"extensionModel":{"name":"mule"},"modelName":"flowRef","modelType":"OPERATION","annotations":{"{http://www.mulesoft.org/schema/mule/documentation}name":"Flow Reference to Common Flow","{http://www.mulesoft.org/schema/mule/documentation}id":"cd5b9667-fcc8-4425-94ca-8ed4503433bb"}}],"componentType":"ROUTE","identifier":{"name":"route","namespace":"mule","namespaceUri":"http://www.mulesoft.org/schema/mule/core"},"location":{"name":"tcdp-report-main-flow","parts":[{"partPath":"tcdp-report-main-flow","partIdentifier":{"identifier":{"name":"sub-flow","namespace":"mule","namespaceUri":"http://www.mulesoft.org/schema/mule/core"},"type":{"name":"SUB_FLOW"}},"fileName":"implementation/lms-tcdp-fetch-data-api.xml","line":11,"column":5},{"partPath":"processors"},{"partPath":"5","partIdentifier":{"identifier":{"name":"choice","namespace":"mule","namespaceUri":"http://www.mulesoft.org/schema/mule/core"},"type":{"name":"ROUTER"}},"fileName":"implementation/lms-tcdp-fetch-data-api.xml","line":57,"column":9},{"partPath":"route"},{"partPath":"0","partIdentifier":{"identifier":{"name":"when","namespace":"mule","namespaceUri":"http://www.mulesoft.org/schema/mule/core"},"type":{"name":"ROUTE"}},"fileName":"implementation/lms-tcdp-fetch-data-api.xml","line":58,"column":4},{"partPath":"processors"},{"partPath":"0","partIdentifier":{"identifier":{"name":"scatter-gather","namespace":"mule","namespaceUri":"http://www.mulesoft.org/schema/mule/core"},"type":{"name":"ROUTER"}},"fileName":"implementation/lms-tcdp-fetch-data-api.xml","line":59,"column":5},{"partPath":"route"},{"partPath":"0","partIdentifier":{"identifier":{"name":"route","namespace":"mule","namespaceUri":"http://www.mulesoft.org/schema/mule/core"},"type":{"name":"ROUTE"}},"fileName":"implementation/lms-tcdp-fetch-data-api.xml","line":60,"column":13}],"location":"tcdp-report-main-flow/processors/5/route/0/processors/0/route/0"},"metadata":{"docAttributes":{},"endColumn":21,"endLine":99,"fileName":"implementation/lms-tcdp-fetch-data-api.xml","fileUri":"file:/C:/Users/Rithika/AnypointStudio/GMMCO/lms-tcdp-sys-app-1.0.1-mule-application/src/main/mule/implementation/lms-tcdp-fetch-data-api.xml","importLocationChain":[],"parserAttributes":{"OPENING_TAG_START_COLUMN":{"type":"java.lang.Integer","value":13},"CLOSING_TAG_END_COLUMN":{"type":"java.lang.Integer","value":21},"OPENING_TAG_END_LINE":{"type":"java.lang.Integer","value":60},"OPENING_TAG_START_LINE":{"type":"java.lang.Integer","value":60},"CLOSING_TAG_START_LINE":{"type":"java.lang.Integer","value":99},"CLOSING_TAG_START_COLUMN":{"type":"java.lang.Integer","value":13},"OPENING_TAG_END_COLUMN":{"type":"java.lang.Integer","value":20},"CLOSING_TAG_END_LINE":{"type":"java.lang.Integer","value":99}},"sourceCode":"\u003croute\u003e\r\n\u003cee:transform doc:name\u003d\"GLMS User Query\" doc:id\u003d\"0ddb209e-0579-4fa0-aaba-6c7d1d064cd9\"\u003e\r\n\u003cee:message\u003e\u003c/ee:message\u003e\r\n\u003cee:variables\u003e\r\n\u003cee:set-variable variableName\u003d\"glms_user_query\"\u003e\u003c![CDATA[%dw 2.0\noutput application/java\n---\n\"SELECT\n    u.id AS \\\"User ID\\\",\n    u.first_name as \\\"Employee Name\\\",\n    u.employee_id as \\\"Employee ID\\\",\n    jr.name AS \\\"Current Job Role\\\",\n    i.name AS \\\"CAT Industry Classification\\\"\nFROM public.\\\"user\\\" u\nJOIN public.job_role jr\n    ON jr.id \u003d u.job_role_id\nJOIN public.industry i\n    ON i.id \u003d jr.industry_id\nWHERE\n    u.id IN (\" ++ ((vars.user_id map ($ as String)) joinBy \",\") ++ \")\n    AND jr.id IN (\" ++ ((vars.job_role_id map ($ as String)) joinBy \",\") ++ \")\n    AND u.deleted_at IS NULL\"]]\u003e\u003c/ee:set-variable\u003e\r\n\u003c/ee:variables\u003e\r\n\u003c/ee:transform\u003e\r\n\u003cee:transform doc:name\u003d\"Set DB Details - User DB\" doc:id\u003d\"b1df6929-3d95-404b-b182-0a2d7a0f50b5\"\u003e\r\n\u003cee:message\u003e\u003c/ee:message\u003e\r\n\u003cee:variables\u003e\r\n\u003cee:set-variable variableName\u003d\"dbDetails\"\u003e\u003c![CDATA[%dw 2.0\noutput application/java\n---\n{\n    \"query\"   : vars.glms_user_query,\n    \"user\"    : Mule::p(\u0027db.user\u0027),\n    \"password\": Mule::p(\u0027secure::db.password\u0027),\n    \"url\"     : Mule::p(\u0027db.userurl\u0027)\n}]]\u003e\u003c/ee:set-variable\u003e\r\n\u003c/ee:variables\u003e\r\n\u003c/ee:transform\u003e\r\n\u003cflow-ref doc:name\u003d\"Flow Reference to Common Flow\" doc:id\u003d\"cd5b9667-fcc8-4425-94ca-8ed4503433bb\" name\u003d\"common-sub-flow\"\u003e\u003c/flow-ref\u003e\r\n\u003c/route\u003e","startColumn":13,"startLine":60},"parameters":[],"extensionModel":{"name":"mule"},"modelName":"route","modelType":"NESTED_ROUTE","annotations":{}},{"directChildren":[{"directChildren":[],"componentType":"OPERATION","identifier":{"name":"transform","namespace":"ee","namespaceUri":"http://www.mulesoft.org/schema/mule/ee/core"},"location":{"name":"tcdp-report-main-flow","parts":[{"partPath":"tcdp-report-main-flow","partIdentifier":{"identifier":{"name":"sub-flow","namespace":"mule","namespaceUri":"http://www.mulesoft.org/schema/mule/core"},"type":{"name":"SUB_FLOW"}},"fileName":"implementation/lms-tcdp-fetch-data-api.xml","line":11,"column":5},{"partPath":"processors"},{"partPath":"5","partIdentifier":{"identifier":{"name":"choice","namespace":"mule","namespaceUri":"http://www.mulesoft.org/schema/mule/core"},"type":{"name":"ROUTER"}},"fileName":"implementation/lms-tcdp-fetch-data-api.xml","line":57,"column":9},{"partPath":"route"},{"partPath":"0","partIdentifier":{"identifier":{"name":"when","namespace":"mule","namespaceUri":"http://www.mulesoft.org/schema/mule/core"},"type":{"name":"ROUTE"}},"fileName":"implementation/lms-tcdp-fetch-data-api.xml","line":58,"column":4},{"partPath":"processors"},{"partPath":"0","partIdentifier":{"identifier":{"name":"scatter-gather","namespace":"mule","namespaceUri":"http://www.mulesoft.org/schema/mule/core"},"type":{"name":"ROUTER"}},"fileName":"implementation/lms-tcdp-fetch-data-api.xml","line":59,"column":5},{"partPath":"route"},{"partPath":"1","partIdentifier":{"identifier":{"name":"route","namespace":"mule","namespaceUri":"http://www.mulesoft.org/schema/mule/core"},"type":{"name":"ROUTE"}},"fileName":"implementation/lms-tcdp-fetch-data-api.xml","line":100,"column":13},{"partPath":"processors"},{"partPath":"0","partIdentifier":{"identifier":{"name":"transform","namespace":"ee","namespaceUri":"http://www.mulesoft.org/schema/mule/ee/core"},"type":{"name":"OPERATION"}},"fileName":"implementation/lms-tcdp-fetch-data-api.xml","line":101,"column":17}],"location":"tcdp-report-main-flow/processors/5/route/0/processors/0/route/1/processors/0"},"metadata":{"docAttributes":{"name":"GLMS Course Query","id":"699bd2c3-2f8a-4f03-b6b2-2fd65be40cb5"},"endColumn":32,"endLine":216,"fileName":"implementation/lms-tcdp-fetch-data-api.xml","fileUri":"file:/C:/Users/Rithika/AnypointStudio/GMMCO/lms-tcdp-sys-app-1.0.1-mule-application/src/main/mule/implementation/lms-tcdp-fetch-data-api.xml","importLocationChain":[],"parserAttributes":{"OPENING_TAG_START_COLUMN":{"type":"java.lang.Integer","value":17},"CLOSING_TAG_END_COLUMN":{"type":"java.lang.Integer","value":32},"OPENING_TAG_END_LINE":{"type":"java.lang.Integer","value":101},"OPENING_TAG_START_LINE":{"type":"java.lang.Integer","value":101},"CLOSING_TAG_START_LINE":{"type":"java.lang.Integer","value":216},"CLOSING_TAG_START_COLUMN":{"type":"java.lang.Integer","value":17},"OPENING_TAG_END_COLUMN":{"type":"java.lang.Integer","value":106},"CLOSING_TAG_END_LINE":{"type":"java.lang.Integer","value":216},"DECLARED_PREFIX":{"type":"java.lang.String","value":"ee"}},"sourceCode":"\u003cee:transform doc:name\u003d\"GLMS Course Query\" doc:id\u003d\"699bd2c3-2f8a-4f03-b6b2-2fd65be40cb5\"\u003e\r\n\u003cee:message\u003e\u003c/ee:message\u003e\r\n\u003cee:variables\u003e\r\n\u003cee:set-variable variableName\u003d\"glms_course_query\"\u003e\u003c![CDATA[%dw 2.0\noutput application/java\n\nvar userIds \u003d ((vars.user_id     default []) map ($ as String)) joinBy \",\"\nvar roleIds \u003d ((vars.job_role_id default []) map ($ as String)) joinBy \",\"\n\n---\n\"WITH base AS (\n    SELECT\n        uc.user_id,\n        uc.deleted_at,\n        uc.reason,\n        uc.curriculum_version_id,\n        c.id        AS curriculum_id,\n        c.name      AS curriculum_name,\n        c.role_id,\n        d.domain_name\n    FROM glms_course.public.user_curriculum uc\n    JOIN glms_course.public.curriculum_version cv\n        ON cv.id \u003d uc.curriculum_version_id\n        AND cv.deleted_at IS NULL\n    JOIN glms_course.public.curriculum c\n        ON c.id \u003d cv.curriculum_id\n        AND c.deleted_at IS NULL\n    JOIN glms_course.public.curriculum_domain cd\n        ON cd.curriculum_id \u003d c.id\n        AND cd.deleted_at IS NULL\n    JOIN glms_course.public.domains d\n        ON d.id \u003d cd.domain_id\n        AND d.deleted_at IS NULL\n    WHERE uc.user_id IN (\" ++ userIds ++ \")\n      AND c.role_id IN (\" ++ roleIds ++ \")\n),\n\nprogram_type_cte AS (\n    SELECT\n        user_id,\n        role_id,\n        CASE\n            WHEN LOWER(domain_name) \u003d \u0027service\u0027 THEN \u0027TCDP\u0027\n            WHEN LOWER(domain_name) \u003d \u0027sales\u0027   THEN \u0027SCDP\u0027\n            ELSE domain_name\n        END AS program_type\n    FROM base\n    WHERE deleted_at IS NULL\n),\n\nexclusion_cte AS (\n    SELECT\n        user_id,\n        role_id,\n        TO_CHAR(deleted_at, \u0027Mon YY\u0027) AS exclusion_month_yy,\n        CASE\n            WHEN EXTRACT(MONTH FROM deleted_at) \u003e\u003d 4\n            THEN CONCAT(\n                    EXTRACT(YEAR FROM deleted_at)::int,\n                    \u0027-\u0027,\n                    RIGHT((EXTRACT(YEAR FROM deleted_at)::int + 1)::text, 2)\n                 )\n            ELSE CONCAT(\n                    (EXTRACT(YEAR FROM deleted_at)::int - 1),\n                    \u0027-\u0027,\n                    RIGHT(EXTRACT(YEAR FROM deleted_at)::text, 2)\n                 )\n        END AS financial_year,\n        reason AS exclusion_reason\n    FROM base\n    WHERE deleted_at IS NOT NULL\n      AND LOWER(domain_name) \u003d \u0027service\u0027\n),\n\ncurriculum_name_cte AS (\n    SELECT\n        user_id,\n        role_id,\n        curriculum_name\n    FROM base\n    WHERE deleted_at IS NULL\n),\n\ncertification_cte AS (\n    SELECT DISTINCT ON (uc.user_id, uc.role_id)\n        uc.user_id,\n        uc.role_id,\n        p.level_name,\n        uc.completed_at AS last_acquired_certification_date\n    FROM glms_course.public.user_certifications uc\n    JOIN glms_course.public.proficiencies p\n        ON p.id \u003d uc.level_id\n    WHERE uc.user_id IN (\" ++ userIds ++ \")\n      AND uc.role_id IN (\" ++ roleIds ++ \")\n      AND uc.status \u003d \u0027completed\u0027\n      AND uc.deleted_at IS NULL\n    ORDER BY uc.user_id, uc.role_id, uc.completed_at DESC\n)\n\nSELECT\n    b.user_id,\n    b.role_id,\n    pt.program_type,\n    cn.curriculum_name,\n    ex.exclusion_month_yy,\n    ex.financial_year,\n    ex.exclusion_reason,\n    ce.level_name,\n    ce.last_acquired_certification_date\nFROM base b\nLEFT JOIN program_type_cte    pt ON pt.user_id \u003d b.user_id AND pt.role_id \u003d b.role_id\nLEFT JOIN curriculum_name_cte cn ON cn.user_id \u003d b.user_id AND cn.role_id \u003d b.role_id\nLEFT JOIN exclusion_cte       ex ON ex.user_id \u003d b.user_id AND ex.role_id \u003d b.role_id\nLEFT JOIN certification_cte   ce ON ce.user_id \u003d b.user_id AND ce.role_id \u003d b.role_id\"]]\u003e\u003c/ee:set-variable\u003e\r\n\u003c/ee:variables\u003e\r\n\u003c/ee:transform\u003e","startColumn":17,"startLine":101},"parameters":[{"groupModelName":"Message","modelName":"setPayload","value":{},"defaultValue":true},{"groupModelName":"Message","modelName":"setAttributes","value":{},"defaultValue":true},{"metadata":{"docAttributes":{},"endColumn":36,"endLine":215,"fileName":"implementation/lms-tcdp-fetch-data-api.xml","fileUri":"file:/C:/Users/Rithika/AnypointStudio/GMMCO/lms-tcdp-sys-app-1.0.1-mule-application/src/main/mule/implementation/lms-tcdp-fetch-data-api.xml","importLocationChain":[],"parserAttributes":{"OPENING_TAG_START_COLUMN":{"type":"java.lang.Integer","value":21},"CLOSING_TAG_END_COLUMN":{"type":"java.lang.Integer","value":36},"OPENING_TAG_END_LINE":{"type":"java.lang.Integer","value":103},"OPENING_TAG_START_LINE":{"type":"java.lang.Integer","value":103},"CLOSING_TAG_START_LINE":{"type":"java.lang.Integer","value":215},"CLOSING_TAG_START_COLUMN":{"type":"java.lang.Integer","value":21},"OPENING_TAG_END_COLUMN":{"type":"java.lang.Integer","value":35},"CLOSING_TAG_END_LINE":{"type":"java.lang.Integer","value":215},"DECLARED_PREFIX":{"type":"java.lang.String","value":"ee"}},"sourceCode":"\u003cee:variables\u003e\r\n\u003cee:set-variable variableName\u003d\"glms_course_query\"\u003e\u003c![CDATA[%dw 2.0\noutput application/java\n\nvar userIds \u003d ((vars.user_id     default []) map ($ as String)) joinBy \",\"\nvar roleIds \u003d ((vars.job_role_id default []) map ($ as String)) joinBy \",\"\n\n---\n\"WITH base AS (\n    SELECT\n        uc.user_id,\n        uc.deleted_at,\n        uc.reason,\n        uc.curriculum_version_id,\n        c.id        AS curriculum_id,\n        c.name      AS curriculum_name,\n        c.role_id,\n        d.domain_name\n    FROM glms_course.public.user_curriculum uc\n    JOIN glms_course.public.curriculum_version cv\n        ON cv.id \u003d uc.curriculum_version_id\n        AND cv.deleted_at IS NULL\n    JOIN glms_course.public.curriculum c\n        ON c.id \u003d cv.curriculum_id\n        AND c.deleted_at IS NULL\n    JOIN glms_course.public.curriculum_domain cd\n        ON cd.curriculum_id \u003d c.id\n        AND cd.deleted_at IS NULL\n    JOIN glms_course.public.domains d\n        ON d.id \u003d cd.domain_id\n        AND d.deleted_at IS NULL\n    WHERE uc.user_id IN (\" ++ userIds ++ \")\n      AND c.role_id IN (\" ++ roleIds ++ \")\n),\n\nprogram_type_cte AS (\n    SELECT\n        user_id,\n        role_id,\n        CASE\n            WHEN LOWER(domain_name) \u003d \u0027service\u0027 THEN \u0027TCDP\u0027\n            WHEN LOWER(domain_name) \u003d \u0027sales\u0027   THEN \u0027SCDP\u0027\n            ELSE domain_name\n        END AS program_type\n    FROM base\n    WHERE deleted_at IS NULL\n),\n\nexclusion_cte AS (\n    SELECT\n        user_id,\n        role_id,\n        TO_CHAR(deleted_at, \u0027Mon YY\u0027) AS exclusion_month_yy,\n        CASE\n            WHEN EXTRACT(MONTH FROM deleted_at) \u003e\u003d 4\n            THEN CONCAT(\n                    EXTRACT(YEAR FROM deleted_at)::int,\n                    \u0027-\u0027,\n                    RIGHT((EXTRACT(YEAR FROM deleted_at)::int + 1)::text, 2)\n                 )\n            ELSE CONCAT(\n                    (EXTRACT(YEAR FROM deleted_at)::int - 1),\n                    \u0027-\u0027,\n                    RIGHT(EXTRACT(YEAR FROM deleted_at)::text, 2)\n                 )\n        END AS financial_year,\n        reason AS exclusion_reason\n    FROM base\n    WHERE deleted_at IS NOT NULL\n      AND LOWER(domain_name) \u003d \u0027service\u0027\n),\n\ncurriculum_name_cte AS (\n    SELECT\n        user_id,\n        role_id,\n        curriculum_name\n    FROM base\n    WHERE deleted_at IS NULL\n),\n\ncertification_cte AS (\n    SELECT DISTINCT ON (uc.user_id, uc.role_id)\n        uc.user_id,\n        uc.role_id,\n        p.level_name,\n        uc.completed_at AS last_acquired_certification_date\n    FROM glms_course.public.user_certifications uc\n    JOIN glms_course.public.proficiencies p\n        ON p.id \u003d uc.level_id\n    WHERE uc.user_id IN (\" ++ userIds ++ \")\n      AND uc.role_id IN (\" ++ roleIds ++ \")\n      AND uc.status \u003d \u0027completed\u0027\n      AND uc.deleted_at IS NULL\n    ORDER BY uc.user_id, uc.role_id, uc.completed_at DESC\n)\n\nSELECT\n    b.user_id,\n    b.role_id,\n    pt.program_type,\n    cn.curriculum_name,\n    ex.exclusion_month_yy,\n    ex.financial_year,\n    ex.exclusion_reason,\n    ce.level_name,\n    ce.last_acquired_certification_date\nFROM base b\nLEFT JOIN program_type_cte    pt ON pt.user_id \u003d b.user_id AND pt.role_id \u003d b.role_id\nLEFT JOIN curriculum_name_cte cn ON cn.user_id \u003d b.user_id AND cn.role_id \u003d b.role_id\nLEFT JOIN exclusion_cte       ex ON ex.user_id \u003d b.user_id AND ex.role_id \u003d b.role_id\nLEFT JOIN certification_cte   ce ON ce.user_id \u003d b.user_id AND ce.role_id \u003d b.role_id\"]]\u003e\u003c/ee:set-variable\u003e\r\n\u003c/ee:variables\u003e","startColumn":21,"startLine":103},"groupModelName":"Set Variables","modelName":"variables","value":{"listOfPojoComponentAstDto":[{"directChildren":[],"componentType":"UNKNOWN","identifier":{"name":"set-variable","namespace":"ee","namespaceUri":"http://www.mulesoft.org/schema/mule/ee/core"},"location":{"name":"tcdp-report-main-flow","parts":[{"partPath":"tcdp-report-main-flow","partIdentifier":{"identifier":{"name":"sub-flow","namespace":"mule","namespaceUri":"http://www.mulesoft.org/schema/mule/core"},"type":{"name":"SUB_FLOW"}},"fileName":"implementation/lms-tcdp-fetch-data-api.xml","line":11,"column":5},{"partPath":"processors"},{"partPath":"5","partIdentifier":{"identifier":{"name":"choice","namespace":"mule","namespaceUri":"http://www.mulesoft.org/schema/mule/core"},"type":{"name":"ROUTER"}},"fileName":"implementation/lms-tcdp-fetch-data-api.xml","line":57,"column":9},{"partPath":"route"},{"partPath":"0","partIdentifier":{"identifier":{"name":"when","namespace":"mule","namespaceUri":"http://www.mulesoft.org/schema/mule/core"},"type":{"name":"ROUTE"}},"fileName":"implementation/lms-tcdp-fetch-data-api.x