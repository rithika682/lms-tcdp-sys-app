ault \"\",\n    \"Date of Certification (Last Aquired)\"  : $.last_acquired_certification_date default \"\"\n}]]\u003e\u003c/ee:set-payload\u003e","startColumn":17,"startLine":246},"parameters":[{"groupModelName":"SetPayload","modelName":"resource","value":{},"defaultValue":true},{"unresolvedValue":"%dw 2.0\noutput application/json\n---\nvars.aggregatedData map {\n\t\"Employee ID\"                           : $.\"Employee ID\"                    default \"\",\n    \"Employee Name\"                         : $.\"Employee Name\"                  default \"\",\n    \"Current Job Role\"                      : $.\"Current Job Role\"               default \"\",\n    \"CAT Industry Classification\"           : $.\"CAT Industry Classification\"    default \"\",\n    \"TCDP Head Count\"                       : $.program_type                     default \"\",\n    \"TCDP Exclusion Month / YY\"             : $.exclusion_month_yy               default \"\",\n    \"FY of Exclusion\"                       : $.financial_year                   default \"\",\n    \"Reason for TCDP Exclusion / Inclusion\" : $.exclusion_reason                 default \"\",\n    \"ILP / Curricula Mapped\"                : $.curriculum_name                  default \"\",\n    \"Current TCDP Certification Level\"      : $.level_name                       default \"\",\n    \"Date of Certification (Last Aquired)\"  : $.last_acquired_certification_date default \"\"\n}","metadata":{"docAttributes":{},"endColumn":22,"endLine":261,"fileName":"implementation/lms-tcdp-fetch-data-api.xml","fileUri":"file:/C:/Users/Rithika/AnypointStudio/GMMCO/lms-tcdp-sys-app-1.0.1-mule-application/src/main/mule/implementation/lms-tcdp-fetch-data-api.xml","importLocationChain":[],"parserAttributes":{"OPENING_TAG_START_COLUMN":{"type":"java.lang.Integer","value":17},"CLOSING_TAG_END_COLUMN":{"type":"java.lang.Integer","value":22},"OPENING_TAG_END_LINE":{"type":"java.lang.Integer","value":246},"OPENING_TAG_START_LINE":{"type":"jav