E":{"type":"java.lang.Integer","value":265},"CLOSING_TAG_START_COLUMN":{"type":"java.lang.Integer","value":9},"OPENING_TAG_END_COLUMN":{"type":"java.lang.Integer","value":140},"CLOSING_TAG_END_LINE":{"type":"java.lang.Integer","value":266},"IS_SELF_CLOSING":{"type":"java.lang.Boolean","value":true}},"sourceCode":"\u003clogger level\u003d\"INFO\" doc:name\u003d\"Log Final Output\" doc:id\u003d\"982bd9d7-4bb6-4c1b-a3f6-c2c6ac36fc32\" message\u003d\"#[output application/json\n---\n{\n \"flowName\": \"tcdp-report-main-flow\",\n \"tracePoint\": \"END\",\n}]\"\u003e\u003c/logger\u003e","startColumn":9,"startLine":265},"groupModelName":"General","modelName":"level","value":{"aString":"INFO"},"defaultValue":true},{"groupModelName":"General","modelName":"category","value":{},"defaultValue":true}],"extensionModel":{"name":"mule"},"modelName":"logger","modelType":"OPERATION","annotations":{"{http://www.mulesoft.org/schema/mule/documentation}name":"Log Final Output","{http://www.mulesoft.org/schema/mule/documentation}id":"982bd9d7-4bb6-4c1b-a3f6-c2c6ac36fc32"}}],"componentType":"SUB_FLOW","identifier":{"name":"sub-flow","namespace":"mule","namespaceUri":"http://www.mulesoft.org/schema/mule/core"},"location":{"name":"tcdp-report-main-flow","parts":[{"partPath":"tcdp-report-main-flow","partIdentifier":{"identifier":{"name":"sub-flow","namespace":"mule","namespaceUri":"http://www.mulesoft.org/schema/mule/core"},"type":{"name":"SUB_FLOW"}},"fileName":"implementation/lms-tcdp-fetch-data-api.xml","line":11,"column":5}],"location":"tcdp-report-main-flow"},"metadata":{"docAttributes":{"id":"18966c1d-17ca-49fd-a1c0-2c6d875d7b80"},"endColumn":16,"endLine":268,"fileName":"implementation/lms-tcdp-fetch-data-api.xml","fileUri":"file:/C:/Users/Rithika/AnypointStudio/GMMCO/lms-tcdp-sys-app-1.0.1-mule-application/src/main/mule/implementation/lms-tcdp-fetch-data-api.xml","importLocationChain":[],"parserAttributes":{"OPENING_TAG_START_COLUMN":{"type":"java.lang.Integer","value":5},"CLOSING_TAG_END_COLUMN":{"type":"java.lang.Integer","value":16},"OPENING_TAG_END_LINE":{"type":"java.lang.Integer","value":11},"OPENING_TAG_START_LINE":{"type":"java.lang.Integer","value":11},"CLOSING_TAG_START_LINE":{"type":"java.lang.Integer","value":268},"CLOSING_TAG_START_COLUMN":{"type":"java.lang.Integer","value":5},"OPENING_TAG_END_COLUMN":{"type":"java.lang.Integer","value":90},"CLOSING_TAG_END_LINE":{"type":"java.lang.Integer","value":268}},"sourceCode":"\u003csub-flow name\u003d\"tcdp-report-main-flow\" doc:id\u003d\"18966c1d-17ca-49fd-a1c0-2c6d875d7b80\"\u003e\r\n\u003clogger level\u003d\"INFO\" doc:name\u003d\"Log Before DB Call\" doc:id\u003d\"7f096c8e-b223-4bec-8fa6-cb3aaf118af8\" message\u003d\"#[output application/json\n---\n{\n \"flowName\": \"tcdp-report-main-flow\",\n \"tracePoint\": \"START\",\n \"message\": \"tcdp-report-main-flow started....\"\n}]\"\u003e\u003c/logger\u003e\r\n\u003cee:transform doc:name\u003d\"Set Query,dbDetails\" doc:id\u003d\"9abffedd-f975-4aca-8c32-e7ffd6e53315\"\u003e\r\n\u003cee:message\u003e\u003c/ee:message\u003e\r\n\u003cee:variables\u003e\r\n\u003cee:set-variable variableName\u003d\"dbDetails\"\u003e\u003c![CDATA[%dw 2.0\noutput application/java\n---\n{\n    \"query\"   : attributes.queryParams.query,\n    \"user\"    : Mule::p(\u0027db.user\u0027),\n    \"password\": Mule::p(\u0027secure::db.password\u0027),\n    \"url\"     : Mule::p(\u0027db.userurl\u0027)\n}]]\u003e\u003c/ee:set-variable\u003e\r\n\u003c/ee:variables\u003e\r\n\u003c/ee:transform\u003e\r\n\u003cflow-ref doc:name\u003d\"Flow Ref to common flow\" doc:id\u003d\"d777c09a-dfe3-4739-a485-725c45ae91ec\" name\u003d\"common-sub-flow\"\u003e\u003c/flow-ref\u003e\r\n\u003cee:transform doc:name\u003d\"Set user_id and job_role_id\" doc:id\u003d\"34ca771c-d44e-4b0a-8422-b3071f0716a1\"\u003e\r\n\u003cee:message\u003e\u003c/ee:message\u003e\r\n\u003cee:variables\u003e\r\n\u003cee:set-variable variableName\u003d\"user_id\"\u003e\u003c![CDATA[%dw 2.0\noutput application/java\n---\npayload map ($.user_id as String)]]\u003e\u003c/ee:set-variable\u003e\r\n\u003cee:set-variable variableName\u003d\"job_role_id\"\u003e\u003c![CDATA[%dw 2.0\noutput application/java\n---\npayload map ($.job_role_id as String)]]\u003e\u003c/ee:set-variable\u003e\r\n\u003c/ee:variables\u003e\r\n\u003c/ee:transform\u003e\r\n\u003clogger level\u003d\"INFO\" doc:name\u003d\"UserId \u0026 RoleIds Logger\" doc:id\u003d\"a7a353f6-d6ff-402d-8f57-c53ea321d83f\" message\u003d\"#[output application/json\n---\n{\n \"flowName\": \"tcdp-report-main-flow\",\n \"tracePoint\": \"BEFORE REQUEST\",\n \"message\": \"tcdp-report-main-flow started...\",\n \"userIds\": write(vars.user_id,\"application/java\"),\n \"roleIds\": write(vars.job_role_id,\"application/java\")\n}]\"\u003e\u003c/logger\u003e\r\n\u003cchoice doc:name\u003d\"Choice\" doc:id\u003d\"562c1c9f-5eb2-4941-a034-853ba85c8f69\"\u003e\r\n\u003cwhen expression\u003d\"#[!isEmpty(vars.user_id) and !isEmpty(vars.job_role_id)]\"\u003e\r\n\u003cscatter-gather doc:name\u003d\"Scatter-Gather - Fetch User and Course Data\" doc:id\u003d\"b782a951-1c68-44d8-bce6-7dcbe9197a0d\"\u003e\r\n\u003croute\u003e\r\n\u003cee:transform doc:name\u003d\"GLMS User Query\" doc:id\u003d\"0ddb209e-0579-4fa0-aaba-6c7d1d064cd9\"\u003e\r\n\u003cee:message\u003e\u003c/ee:message\u003e\r\n\u003cee:variables\u003e\r\n\u003cee:set-variable variableName\u003d\"glms_user_query\"\u003e\u003c![CDATA[%dw 2.0\noutput application/java\n---\n\"SELECT\n    u.id AS \\\"User ID\\\",\n    u.first_name as \\\"Employee Name\\\",\n    u.employee_id as \\\"Employee ID\\\",\n    jr.name AS \\\"Current Job Role\\\",\n    i.name AS \\\"CAT Industry Classification\\\"\nFROM public.\\\"user\\\" u\nJOIN public.job_role jr\n    ON jr.id \u003d u.job_role_id\nJOIN public.industry i\n    ON i.id \u003d jr.industry_id\nWHERE\n    u.id IN (\" ++ ((vars.user_id map ($ as String)) joinBy \",\") ++ \")\n    AND jr.id IN (\" ++ ((vars.job_role_id map ($ as String)) joinBy \",\") ++ \")\n    AND u.deleted_at IS NULL\"]]\u003e\u003c/ee:set-variable\u003e\r\n\u003c/ee:variables\u003e\r\n\u003c/ee:transform\u003e\r\n\u003cee:transform doc:name\u003d\"Set DB Details - User DB\" doc:id\u003d\"b1df6929-3d95-404b-b182-0a2d7a0f50b5\"\u003e\r\n\u003cee:message\u003e\u003c/ee:message\u003e\r\n\u003cee:variables\u003e\r\n\u003cee:set-variable variableName\u003d\"dbDetails\"\u003e\u003c![CDATA[%dw 2.0\noutput application/java\n---\n{\n    \"query\"   : vars.glms_user_query,\n    \"user\"    : Mule::p(\u0027db.user\u0027),\n    \"password\": Mule::p(\u0027secure::db.password\u0027),\n    \"url\"     : Mule::p(\u0027db.userurl\u0027)\n}]]\u003e\u003c/ee:set-variable\u003e\r\n\u003c/ee:variables\u003e\r\n\u003c/ee:transform\u003e\r\n\u003cflow-ref doc:name\u003d\"Flow Reference to Common Flow\" doc:id\u003d\"cd5b9667-fcc8-4425-94ca-8ed4503433bb\" name\u003d\"common-sub-flow\"\u003e\u003c/flow-ref\u003e\r\n\u003c/route\u003e\r\n\u003croute\u003e\r\n\u003cee:transform doc:name\u003d\"GLMS Course Query\" doc:id\u003d\"699bd2c3-2f8a-4f03-b6b2-2fd65be40cb5\"\u003e\r\n\u003cee:message\u003e\u003c/ee:message\u003e\r\n\u003cee:variables\u003e\r\n\u003cee:set-variable variableName\u003d\"glms_course_query\"\u003e\u003c![CDATA[%dw 2.0\noutput application/java\n\nvar userIds \u003d ((vars.user_id     default []) map ($ as String)) joinBy \",\"\nvar roleIds \u003d ((vars.job_role_id default []) map ($ as String)) joinBy \",\"\n\n---\n\"WITH base AS (\n    SELECT\n        uc.user_id,\n        uc.deleted_at,\n        uc.reason,\n        uc.curriculum_version_id,\n        c.id        AS curriculum_id,\n        c.name      AS curriculum_name,\n        c.role_id,\n        d.domain_name\n    FROM glms_course.public.user_curriculum uc\n    JOIN glms_course.public.curriculum_version cv\n        ON cv.id \u003d uc.curriculum_version_id\n        AND cv.deleted_at IS NULL\n    JOIN glms_course.public.curriculum c\n        ON c.id \u003d cv.curriculum_id\n        AND c.deleted_at IS NULL\n    JOIN glms_course.public.curriculum_domain cd\n        ON cd.curriculum_id \u003d c.id\n        AND cd.deleted_at IS NULL\n    JOIN glms_course.public.domains d\n        ON d.id \u003d cd.domain_id\n        AND d.deleted_at IS NULL\n    WHERE uc.user_id IN (\" ++ userIds ++ \")\n      AND c.role_id IN (\" ++ roleIds ++ \")\n),\n\nprogram_type_cte AS (\n    SELECT\n        user_id,\n        role_id,\n        CASE\n            WHEN LOWER(domain_name) \u003d \u0027service\u0027 THEN \u0027TCDP\u0027\n            WHEN LOWER(domain_name) \u003d \u0027sales\u0027   THEN \u0027SCDP\u0027\n            ELSE domain_name\n        END AS program_type\n    FROM base\n    WHERE deleted_at IS NULL\n),\n\nexclusion_cte AS (\n    SELECT\n        user_id,\n        role_id,\n        TO_CHAR(deleted_at, \u0027Mon YY\u0027) AS exclusion_month_yy,\n        CASE\n            WHEN EXTRACT(MONTH FROM deleted_at) \u003e\u003d 4\n            THEN CONCAT(\n                    EXTRACT(YEAR FROM deleted_at)::int,\n                    \u0027-\u0027,\n                    RIGHT((EXTRACT(YEAR FROM deleted_at)::int + 1)::text, 2)\n                 )\n            ELSE CONCAT(\n                    (EXTRACT(YEAR FROM deleted_at)::int - 1),\n                    \u0027-\u0027,\n                    RIGHT(EXTRACT(YEAR FROM deleted_at)::text, 2)\n                 )\n        END AS financial_year,\n        reason AS exclusion_reason\n    FROM base\n    WHERE deleted_at IS NOT NULL\n      AND LOWER(domain_name) \u003d \u0027service\u0027\n),\n\ncurriculum_name_cte AS (\n    SELECT\n        user_id,\n        role_id,\n        curriculum_name\n    FROM base\n    WHERE deleted_at IS NULL\n),\n\ncertification_cte AS (\n    SELECT DISTINCT ON (uc.user_id, uc.role_id)\n        uc.user_id,\n        uc.role_id,\n        p.level_name,\n        uc.completed_at AS last_acquired_certification_date\n    FROM glms_course.public.user_certifications uc\n    JOIN glms_course.public.proficiencies p\n        ON p.id \u003d uc.level_id\n    WHERE uc.user_id IN (\" ++ userIds ++ \")\n      AND uc.role_id IN (\" ++ roleIds ++ \")\n      AND uc.status \u003d \u0027completed\u0027\n      AND uc.deleted_at IS NULL\n    ORDER BY uc.user_id, uc.role_id, uc.completed_at DESC\n)\n\nSELECT\n    b.user_id,\n    b.role_id,\n    pt.program_type,\n    cn.curriculum_name,\n    ex.exclusion_month_yy,\n    ex.financial_year,\n    ex.exclusion_reason,\n    ce.level_name,\n    ce.last_acquired_certification_date\nFROM base b\nLEFT JOIN program_type_cte    pt ON pt.user_id \u003d b.user_id AND pt.role_id \u003d b.role_id\nLEFT JOIN curriculum_name_cte cn ON cn.user_id \u003d b.user_id AND cn.role_id \u003d b.role_id\nLEFT JOIN exclusion_cte       ex ON ex.user_id \u003d b.user_id AND ex.role_id \u003d b.role_id\nLEFT JOIN certification_cte   ce ON ce.user_id \u003d b.user_id AND ce.role_id \u003d b.role_id\"]]\u003e\u003c/ee:set-variable\u003e\r\n\u003c/ee:variables\u003e\r\n\u003c/ee:transform\u003e\r\n\u003cee:transform doc:name\u003d\"Set DB Details - Course DB\" doc:id\u003d\"c6e258c6-c346-4980-ab09-07d2fbbfc0c5\"\u003e\r\n\u003cee:message\u003e\u003c/ee:message\u003e\r\n\u003cee:variables\u003e\r\n\u003cee:set-variable variableName\u003d\"dbDetails\"\u003e\u003c![CDATA[%dw 2.0\noutput application/java\n---\n{\n    \"query\"   : vars.glms_course_query,\n    \"user\"    : Mule::p(\u0027db.user\u0027),\n    \"password\": Mule::p(\u0027secure::db.password\u0027),\n    \"url\"     : Mule::p(\u0027db.courseurl\u0027)\n}]]\u003e\u003c/ee:set-variable\u003e\r\n\u003c/ee:variables\u003e\r\n\u003c/ee:transform\u003e\r\n\u003cflow-ref doc:name\u003d\"Flow Reference to Common Flow\" doc:id\u003d\"ad185b29-eefb-4cd7-8e14-5190e1d1537c\" name\u003d\"common-sub-flow\"\u003e\u003c/flow-ref\u003e\r\n\u003c/route\u003e\r\n\u003c/scatter-gather\u003e\r\n\u003c/when\u003e\r\n\u003cotherwise\u003e\r\n\u003clogger level\u003d\"INFO\" doc:name\u003d\"Logger\" doc:id\u003d\"52d1fc42-7f58-4e48-8003-5b5affdb254a\" message\u003d\"#[output application/json\n---\n{\n \"flowName\": \"tcdp-report-main-flow\",\n \"tracePoint\": \"ERROR\",\n \"message\": \"No Data\"\n}]\"\u003e\u003c/logger\u003e\r\n\u003c/otherwise\u003e\r\n\u003c/choice\u003e\r\n\u003cset-variable variableName\u003d\"aggregatedData\" doc:name\u003d\"Aggregate User and Course Data\" doc:id\u003d\"496a5405-7e55-4dcd-a5f1-a30b8c8bd63a\" value\u003d\"#[%dw 2.0\noutput application/json\n\nvar users \u003d payload.\u00270\u0027.payload default []\nvar tcdp  \u003d payload.\u00271\u0027.payload default []\n\n---\n((users ++ tcdp) groupBy ((item) -\u003e \n    (item.\"User ID\" default item.user_id) as String))\n  pluck (items, key) -\u003e\n    items reduce ((item, acc \u003d {}) -\u003e acc ++ item)]\"\u003e\u003c/set-variable\u003e\r\n\u003cee:transform doc:name\u003d\"Transform to Final Output\" doc:id\u003d\"3569a943-c303-4976-9919-29197cf5fd69\"\u003e\r\n\u003cee:message\u003e\r\n\u003cee:set-payload\u003e\u003c![CDATA[%dw 2.0\noutput application/json\n---\nvars.aggregatedData map {\n\t\"Employee ID\"                           : $.\"Employee ID\"                    default \"\",\n    \"Employee Name\"                         : $.\"Employee Name\"                  default \"\",\n    \"Current Job Role\"                      : $.\"Current Job Role\"               default \"\",\n    \"CAT Industry Classification\"           : $.\"CAT Industry Classification\"    default \"\",\n    \"TCDP Head Count\"                       : $.program_type                     default \"\",\n    \"TCDP Exclusion Month / YY\"             : $.exclusion_month_yy               default \"\",\n    \"FY of Exclusion\"                       : $.financial_year                   default \"\",\n    \"Reason for TCDP Exclusion / Inclusion\" : $.exclusion_reason                 default \"\",\n    \"ILP / Curricula Mapped\"                : $.curriculum_name                  default \"\",\n    \"Current TCDP Certification Level\"      : $.level_name                       default \"\",\n    \"Date of Certification (Last Aquired)\"  : $.last_acquired_certification_date default \"\"\n}]]\u003e\u003c/ee:set-payload\u003e\r\n\u003c/ee:message\u003e\r\n\u003c/ee:transform\u003e\r\n\u003clogger level\u003d\"INFO\" doc:name\u003d\"Log Final Output\" doc:id\u003d\"982bd9d7-4bb6-4c1b-a3f6-c2c6ac36fc32\" message\u003d\"#[output application/json\n---\n{\n \"flowName\": \"tcdp-report-main-flow\",\n \"tracePoint\": \"END\",\n}]\"\u003e\u003c/logger\u003e\r\n\u003c/sub-flow\u003e","startColumn":5,"startLine":11},"parameters":[{"unresolvedValue":"tcdp-report-main-flow","metadata":{"docAttributes":{"id":"18966c1d-17ca-49fd-a1c0-2c6d875d7b80"},"endColumn":16,"endLine":268,"fileName":"implementation/lms-tcdp-fetch-data-api.xml","fileUri":"file:/C:/Users/Rithika/AnypointStudio/GMMCO/lms-tcdp-sys-app-1.0.1-mule-application/src/main/mule/implementation/lms-tcdp-fetch-data-api.xml","importLocationChain":[],"parserAttributes":{"OPENING_TAG_START_COLUMN":{"type":"java.lang.Integer","value":5},"CLOSING_TAG_END_COLUMN":{"type":"java.lang.Integer","value":16},"OPENING_TAG_END_LINE":{"type":"java.lang.Integer","value":11},"OPENING_TAG_START_LINE":{"type":"java.lang.Integer","value":11},"CLOSING_TAG_START_LINE":{"type":"java.lang.Integer","value":268},"CLOSING_TAG_START_COLUMN":{"type":"java.lang.Integer","value":5},"OPENING_TAG_END_COLUMN":{"type":"java.lang.Integer","value":90},"CLOSING_TAG_END_LINE":{"type":"java.lang.Integer","value":268}},"sourceCode":"\u003csub-flow name\u003d\"tcdp-report-main-flow\" doc:id\u003d\"18966c1d-17ca-49fd-a1c0-2c6d875d7b80\"\u003e\r\n\u003clogger level\u003d\"INFO\" doc:name\u003d\"Log Before DB Call\" doc:id\u003d\"7f096c8e-b223-4bec-8fa6-cb3aaf118af8\" message\u003d\"#[output application/json\n---\n{\n \"flowName\": \"tcdp-report-main-flow\",\n \"tracePoint\": \"START\",\n \"message\": \"tcdp-report-main-flow started....\"\n}]\"\u003e\u003c/logger\u003e\r\n\u003cee:transform doc:name\u003d\"Set Query,dbDetails\" doc:id\u003d\"9abffedd-f975-4aca-8c32-e7ffd6e53315\"\u003e\r\n\u003cee:message\u003e\u003c/ee:message\u003e\r\n\u003cee:variables\u003e\r\n\u003cee:set-variable variableName\u003d\"dbDetails\"\u003e\u003c![CDATA[%dw 2.0\noutput application/java\n---\n{\n    \"query\"   : attributes.queryParams.query,\n    \"user\"    : Mule::p(\u0027db.user\u0027),\n    \"password\": Mule::p(\u0027secure::db.password\u0027),\n    \"url\"     : Mule::p(\u0027db.userurl\u0027)\n}]]\u003e\u003c/ee:set-variable\u003e\r\n\u003c/ee:variables\u003e\r\n\u003c/ee:transform\u003e\r\n\u003cflow-ref doc:name\u003d\"Flow Ref to common flow\" doc:id\u003d\"d777c09a-dfe3-4739-a485-725c45ae91ec\" name\u003d\"common-sub-flow\"\u003e\u003c/flow-ref\u003e\r\n\u003cee:transform doc:name\u003d\"Set user_id and job_role_id\" doc:id\u003d\"34ca771c-d44e-4b0a-8422-b3071f0716a1\"\u003e\r\n\u003cee:message\u003e\u003c/ee:message\u003e\r\n\u003cee:variables\u003e\r\n\u003cee:set-variable variableName\u003d\"user_id\"\u003e\u003c![CDATA[%dw 2.0\noutput application/java\n---\npayload map ($.user_id as String)]]\u003e\u003c/ee:set-variable\u003e\r\n\u003cee:set-variable variableName\u003d\"job_role_id\"\u003e\u003c![CDATA[%dw 2.0\noutput application/java\n---\npayload map ($.job_role_id as String)]]\u003e\u003c/ee:set-variable\u003e\r\n\u003c/ee:variables\u003e\r\n\u003c/ee:transform\u003e\r\n\u003clogger level\u003d\"INFO\" doc:name\u003d\"UserId \u0026 RoleIds Logger\" doc:id\u003d\"a7a353f6-d6ff-402d-8f57-c53ea321d83f\" message\u003d\"#[output application/json\n---\n{\n \"flowName\": \"tcdp-report-main-flow\",\n \"tracePoint\": \"BEFORE REQUEST\",\n \"message\": \"tcdp-report-main-flow started...\",\n \"userIds\": write(vars.user_id,\"application/java\"),\n \"roleIds\": write(vars.job_role_id,\"application/java\")\n}]\"\u003e\u003c/logger\u003e\r\n\u003cchoice doc:name\u003d\"Choice\" doc:id\u003d\"562c1c9f-5eb2-4941-a034-853ba85c8f69\"\u003e\r\n\u003cwhen expression\u003d\"#[!isEmpty(vars.user_id) and !isEmpty(vars.job_role_id)]\"\u003e\r\n\u003cscatter-gather doc:name\u003d\"Scatter-Gather - Fetch User and Course Data\" doc:id\u003d\"b782a951-1c68-44d8-bce6-7dcbe9197a0d\"\u003e\r\n\u003croute\u003e\r\n\u003cee:transform doc:name\u003d\"GLMS User Query\" doc:id\u003d\"0ddb209e-0579-4fa0-aaba-6c7d1d064cd9\"\u003e\r\n\u003cee:message\u003e\u003c/ee:message\u003e\r\n\u003cee:variables\u003e\r\n\u003cee:set-variable variableName\u003d\"glms_user_query\"\u003e\u003c![CDATA[%dw 2.0\noutput application/java\n---\n\"SELECT\n    u.id AS \\\"User ID\\\",\n    u.first_name as \\\"Employee Name\\\",\n    u.employee_id as \\\"Employee ID\\\",\n    jr.name AS \\\"Current Job Role\\\",\n    i.name AS \\\"CAT Industry Classification\\\"\nFROM public.\\\"user\\\" u\nJOIN public.job_role jr\n    ON jr.id \u003d u.job_role_id\nJOIN public.industry i\n    ON i.id \u003d jr.industry_id\nWHERE\n    u.id IN (\" ++ ((vars.user_id map ($ as String)) joinBy \",\") ++ \")\n    AND jr.id IN (\" ++ ((vars.job_role_id map ($ as String)) joinBy \",\") ++ \")\n    AND u.deleted_at IS NULL\"]]\u003e\u003c/ee:set-variable\u003e\r\n\u003c/ee:variables\u003e\r\n\u003c/ee:transform\u003e\r\n\u003cee:transform doc:name\u003d\"Set DB Details - User DB\" doc:id\u003d\"b1df6929-3d95-404b-b182-0a2d7a0f50b5\"\u003e\r\n\u003cee:message\u003e\u003c/ee:message\u003e\r\n\u003cee:variables\u003e\r\n\u003cee:set-variable variableName\u003d\"dbDetails\"\u003e\u003c![CDATA[%dw 2.0\noutput application/java\n---\n{\n    \"query\"   : vars.glms_user_query,\n    \"user\"    : Mule::p(\u0027db.user\u0027),\n    \"password\": Mule::p(\u0027secure::db.password\u0027),\n    \"url\"     : Mule::p(\u0027db.userurl\u0027)\n}]]\u003e\u003c/ee:set-variable\u003e\r\n\u003c/ee:variables\u003e\r\n\u003c/ee:transform\u003e\r\n\u003cflow-ref doc:name\u003d\"Flow Reference to Common Flow\" doc:id\u003d\"cd5b9667-fcc8-4425-94ca-8ed4503433bb\" name\u003d\"common-sub-flow\"\u003e\u003c/flow-ref\u003e\r\n\u003c/route\u003e\r\n\u003croute\u003e\r\n\u003cee:transform doc:name\u003d\"GLMS Course Query\" doc:id\u003d\"699bd2c3-2f8a-4f03-b6b2-2fd65be40cb5\"\u003e\r\n\u003cee:message\u003e\u003c/ee:message\u003e\r\n\u003cee:variables\u003e\r\n\u003cee:set-variable variableName\u003d\"glms_course_query\"\u003e\u003c![CDATA[%dw 2.0\noutput application/java\n\nvar userIds \u003d ((vars.user_id     default []) map ($ as String)) joinBy \",\"\nvar roleIds \u003d ((vars.job_role_id default []) map ($ as String)) joinBy \",\"\n\n---\n\"WITH base AS (\n    SELECT\n        uc.user_id,\n        uc.deleted_at,\n        uc.reason,\n        uc.curriculum_version_id,\n        c.id        AS curriculum_id,\n        c.name      AS curriculum_name,\n        c.role_id,\n        d.domain_name\n    FROM glms_course.public.user_curriculum uc\n    JOIN glms_course.public.curriculum_version cv\n        ON cv.id \u003d uc.curriculum_version_id\n        AND cv.deleted_at IS NULL\n    JOIN glms_course.public.curriculum c\n        ON c.id \u003d cv.curriculum_id\n        AND c.deleted_at IS NULL\n    JOIN glms_course.public.curriculum_domain cd\n        ON cd.curriculum_id \u003d c.id\n        AND cd.deleted_at IS NULL\n    JOIN glms_course.public.domains d\n        ON d.id \u003d cd.domain_id\n        AND d.deleted_at IS NULL\n    WHERE uc.user_id IN (\" ++ userIds ++ \")\n      AND c.role_id IN (\" ++ roleIds ++ \")\n),\n\nprogram_type_cte AS (\n    SELECT\n        user_id,\n        role_id,\n        CASE\n            WHEN LOWER(domain_name) \u003d \u0027service\u0027 THEN \u0027TCDP\u0027\n            WHEN LOWER(domain_name) \u003d \u0027sales\u0027   THEN \u0027SCDP\u0027\n            ELSE domain_name\n        END AS program_type\n    FROM base\n    WHERE deleted_at IS NULL\n),\n\nexclusion_cte AS (\n    SELECT\n        user_id,\n        role_id,\n        TO_CHAR(deleted_at, \u0027Mon YY\u0027) AS exclusion_month_yy,\n        CASE\n            WHEN EXTRACT(MONTH FROM deleted_at) \u003e\u003d 4\n            THEN CONCAT(\n                    EXTRACT(YEAR FROM deleted_at)::int,\n                    \u0027-\u0027,\n                    RIGHT((EXTRACT(YEAR FROM deleted_at)::int + 1)::text, 2)\n                 )\n            ELSE CONCAT(\n                    (EXTRACT(YEAR FROM deleted_at)::int - 1),\n                    \u0027-\u0027,\n                    RIGHT(EXTRACT(YEAR FROM deleted_at)::text, 2)\n                 )\n        END AS financial_year,\n        reason AS exclusion_reason\n    FROM base\n    WHERE deleted_at IS NOT NULL\n      AND LOWER(domain_name) \u003d \u0027service\u0027\n),\n\ncurriculum_name_cte AS (\n    SELECT\n        user_id,\n        role_id,\n        curriculum_name\n    FROM base\n    WHERE deleted_at IS NULL\n),\n\ncertification_cte AS (\n    SELECT DISTINCT ON (uc.user_id, uc.role_id)\n        uc.user_id,\n        uc.role_id,\n        p.level_name,\n        uc.completed_at AS last_acquired_certification_date\n    FROM glms_course.public.user_certifications uc\n    JOIN glms_course.public.proficiencies p\n        ON p.id \u003d uc.level_id\n    WHERE uc.user_id IN (\" ++ userIds ++ \")\n      AND uc.role_id IN (\" ++ roleIds ++ \")\n      AND uc.status \u003d \u0027completed\u0027\n      AND uc.deleted_at IS NULL\n    ORDER BY uc.user_id, uc.role_id, uc.completed_at DESC\n)\n\nSELECT\n    b.user_id,\n    b.role_id,\n    pt.program_type,\n    cn.curriculum_name,\n    ex.exclusion_month_yy,\n    ex.financial_year,\n    ex.exclusion_reason,\n    ce.level_name,\n    ce.last_acquired_certification_date\nFROM base b\nLEFT JOIN program_type_cte    pt ON pt.user_id \u003d b.user_id AND pt.role_id \u003d b.role_id\nLEFT JOIN curriculum_name_cte cn ON cn.user_id \u003d b.user_id AND cn.role_id \u003d b.role_id\nLEFT JOIN exclusion_cte       ex ON ex.user_id \u003d b.user_id AND ex.role_id \u003d b.role_id\nLEFT JOIN certification_cte   ce ON ce.user_id \u003d b.user_id AND ce.role_id \u003d b.role_id\"]]\u003e\u003c/ee:set-variable\u003e\r\n\u003c/ee:variables\u003e\r\n\u003c/ee:transform\u003e\r\n\u003cee:transform doc:name\u003d\"Set DB Details - Course DB\" doc:id\u003d\"c6e258c6-c346-4980-ab09-07d2fbbfc0c5\"\u003e\r\n\u003cee:message\u003e\u003c/ee:message\u003e\r\n\u003cee:variables\u003e\r\n\u003cee:set-variable variableName\u003d\"dbDetails\"\u003e\u003c![CDATA[%dw 2.0\noutput application/java\n---\n{\n    \"query\"   : vars.glms_course_query,\n    \"user\"    : Mule::p(\u0027db.user\u0027),\n    \"password\": Mule::p(\u0027secure::db.password\u0027),\n    \"url\"     : Mule::p(\u0027db.courseurl\u0027)\n}]]\u003e\u003c/ee:set-variable\u003e\r\n\u003c/ee:variables\u003e\r\n\u003c/ee:transform\u003e\r\n\u003cflow-ref doc:name\u003d\"Flow Reference to Common Flow\" doc:id\u003d\"ad185b29-eefb-4cd7-8e14-5190e1d1537c\" name\u003d\"common-sub-flow\"\u003e\u003c/flow-ref\u003e\r\n\u003c/route\u003e\r\n\u003c/scatter-gather\u003e\r\n\u003c/when\u003e\r\n\u003cotherwise\u003e\r\n\u003clogger level\u003d\"INFO\" doc:name\u003d\"Logger\" doc:id\u003d\"52d1fc42-7f58-4e48-8003-5b5affdb254a\" message\u003d\"#[output application/json\n---\n{\n \"flowName\": \"tcdp-report-main-flow\",\n \"tracePoint\": \"ERROR\",\n \"message\": \"No Data\"\n}]\"\u003e\u003c/logger\u003e\r\n\u003c/otherwise\u003e\r\n\u003c/choice\u003e\r\n\u003cset-variable variableName\u003d\"aggregatedData\" doc:name\u003d\"Aggregate User and Course Data\" doc:id\u003d\"496a5405-7e55-4dcd-a5f1-a30b8c8bd63a\" value\u003d\"#[%dw 2.0\noutput application/json\n\nvar users \u003d payload.\u00270\u0027.payload default []\nvar tcdp  \u003d payload.\u00271\u0027.payload default []\n\n---\n((users ++ tcdp) groupBy ((item) -\u003e \n    (item.\"User ID\" default item.user_id) as String))\n  pluck (items, key) -\u003e\n    items reduce ((item, acc \u003d {}) -\u003e acc ++ item)]\"\u003e\u003c/set-variable\u003e\r\n\u003cee:transform doc:name\u003d\"Transform to Final Output\" doc:id\u003d\"3569a943-c303-4976-9919-29197cf5fd69\"\u003e\r\n\u003cee:message\u003e\r\n\u003cee:set-payload\u003e\u003c![CDATA[%dw 2.0\noutput application/json\n---\nvars.aggregatedData map {\n\t\"Employee ID\"                           : $.\"Employee ID\"                    default \"\",\n    \"Employee Name\"                         : $.\"Employee Name\"                  default \"\",\n    \"Current Job Role\"                      : $.\"Current Job Role\"               default \"\",\n    \"CAT Industry Classification\"           : $.\"CAT Industry Classification\"    default \"\",\n    \"TCDP Head Count\"                       : $.program_type                     default \"\",\n    \"TCDP Exclusion Month / YY\"             : $.exclusion_month_yy               default \"\",\n    \"FY of Exclusion\"                       : $.financial_year                   default \"\",\n    \"Reason for TCDP Exclusion / Inclusion\" : $.exclusion_reason                 default \"\",\n    \"ILP / Curricula Mapped\"                : $.curriculum_name                  default \"\",\n    \"Current TCDP Certification Level\"      : $.level_name                       default \"\",\n    \"Date of Certification (Last Aquired)\"  : $.last_acquired_certification_date default \"\"\n}]]\u003e\u003c/ee:set-payload\u003e\r\n\u003c/ee:message\u003e\r\n\u003c/ee:transform\u003e\r\n\u003clogger level\u003d\"INFO\" doc:name\u003d\"Log Final Output\" doc:id\u003d\"982bd9d7-4bb6-4c1b-a3f6-c2c6ac36fc32\" message\u003d\"#[output application/json\n---\n{\n \"flowName\": \"tcdp-report-main-flow\",\n \"tracePoint\": \"END\",\n}]\"\u003e\u003c/logger\u003e\r\n\u003c/sub-flow\u003e","startColumn":5,"startLine":11},"groupModelName":"General","modelName":"name","value":{"aString":"tcdp-report-main-flow"},"defaultValue":false}],"componentId":"tcdp-report-main-flow","extensionModel":{"name":"mule"},"modelName":"subFlow","modelType":"CONSTRUCT","annotations":{"{http://www.mulesoft.org/schema/mule/documentation}id":"18966c1d-17ca-49fd-a1c0-2c6d875d7b80"}}],"errorTypeRepository":{"hierarchy":[{"identifier":"ANY","namespace":"MULE","internal":false,"children":[{"identifier":"CONNECTIVITY","namespace":"MULE","internal":false,"children":[{"identifier":"CONNECTIVITY","namespace":"SOCKETS","internal":false,"children":[{"identifier":"CONNECTION_TIMEOUT","namespace":"SOCKETS","internal":false,"children":[]},{"identifier":"UNKNOWN_HOST","namespace":"SOCKETS","internal":false,"children":[]}]},{"identifier":"RETRY_EXHAUSTED","namespace":"MULE","internal":false,"children":[{"identifier":"RETRY_EXHAUSTED","namespace":"APIKIT","internal":false,"children":[]},{"identifier":"RETRY_EXHAUSTED","namespace":"EE","internal":false,"children":[]},{"identifier":"RETRY_EXHAUSTED","namespace":"SOCKETS","internal":false,"children":[]},{"identifier":"RETRY_EXHAUSTED","namespace":"HTTP","internal":false,"children":[]},{"identifier":"RETRY_EXHAUSTED","namespace":"DB","internal":false,"children":[]}]},{"identifier":"CONNECTIVITY","namespace":"HTTP","internal":false,"children":[]},{"identifier":"CONNECTIVITY","namespace":"APIKIT","internal":false,"children":[]},{"identifier":"CONNECTIVITY","namespace":"EE","internal":false,"children":[]},{"identifier":"CONNECTIVITY","namespace":"DB","internal":false,"children":[{"identifier":"INVALID_DATABASE","namespace":"DB","internal":false,"children":[]},{"identifier":"CANNOT_LOAD_DRIVER","namespace":"DB","internal":false,"children":[]},{"identifier":"INVALID_CREDENTIALS","namespace":"DB","internal":false,"children":[]},{"identifier":"CANNOT_REACH","namespace":"DB","internal":false,"children":[]}]}]},{"identifier":"QUERY_EXECUTION","namespace":"DB","internal":false,"children":[]},{"identifier":"GATEWAY_TIMEOUT","namespace":"HTTP","internal":false,"children":[]},{"identifier":"SERVICE_UNAVAILABLE","namespace":"HTTP","internal":false,"children":[]},{"identifier":"VALIDATION","namespace":"MULE","internal":false,"children":[{"identifier":"DUPLICATE_MESSAGE","namespace":"MULE","internal":false,"children":[]}]},{"identifier":"TRANSFORMATION","namespace":"MULE","internal":false,"children":[{"identifier":"TRANSFORMATION","namespace":"HTTP","internal":false,"children":[]}]},{"identifier":"MOVED_TEMPORARILY","namespace":"HTTP","internal":false,"children":[]},{"identifier":"INTERNAL_SERVER_ERROR","namespace":"HTTP","internal":false,"children":[]},{"identifier":"EXPRESSION","namespace":"MULE","internal":false,"children":[]},{"identifier":"TIMEOUT","namespace":"MULE","internal":false,"children":[]},{"identifier":"TOO_MANY_REQUESTS","namespace":"HTTP","internal":false,"children":[]},{"identifier":"ANY","namespace":"APIKIT","internal":false,"children":[{"identifier":"UNSUPPORTED_MEDIA_TYPE","namespace":"APIKIT","internal":false,"children":[]},{"identifier":"NOT_FOUND","namespace":"APIKIT","internal":false,"children":[]},{"identifier":"METHOD_NOT_ALLOWED","namespace":"APIKIT","internal":false,"children":[]},{"identifier":"NOT_IMPLEMENTED","namespace":"APIKIT","internal":false,"children":[]},{"identifier":"NOT_ACCEPTABLE","namespace":"APIKIT","internal":false,"children":[]},{"identifier":"BAD_REQUEST","namespace":"APIKIT","internal":false,"children":[]}]},{"identifier":"BAD_GATEWAY","namespace":"HTTP","internal":false,"children":[]},{"identifier":"MULTIPLE_CHOICES","namespace":"HTTP","internal":false,"children":[]},{"identifier":"MOVED_PERMANENTLY","namespace":"HTTP","internal":false,"children":[]},{"identifier":"NOT_MODIFIED","namespace":"HTTP","internal":false,"children":[]},{"identifier":"TRANSACTION","namespace":"MULE","internal":false,"children":[]},{"identifier":"BAD_REQUEST","namespace":"HTTP","internal":false,"children":[]},{"identifier":"PARSING","namespace":"HTTP","internal":false,"children":[]},{"identifier":"LENGTH_EXCEEDED","namespace":"SOCKETS","internal":false,"children":[]},{"identifier":"SEE_OTHER","namespace":"HTTP","internal":false,"children":[]},{"identifier":"REDELIVERY_EXHAUSTED","namespace":"MULE","internal":false,"children":[]},{"identifier":"UNSUPPORTED_MEDIA_TYPE","namespace":"HTTP","internal":false,"children":[]},{"identifier":"TIMEOUT","namespace":"HTTP","internal":false,"children":[]},{"identifier":"NOT_ACCEPTABLE","namespace":"HTTP","internal":false,"children":[]},{"identifier":"ROUTING","namespace":"MULE","internal":false,"children":[{"identifier":"COMPOSITE_ROUTING","namespace":"MULE","internal":false,"children":[]}]},{"identifier":"METHOD_NOT_ALLOWED","namespace":"HTTP","internal":false,"children":[]},{"identifier":"STREAM_MAXIMUM_SIZE_EXCEEDED","namespace":"MULE","internal":false,"children":[]},{"identifier":"SECURITY","namespace":"MULE","internal":false,"children":[{"identifier":"SERVER_SECURITY","namespace":"MULE","internal":false,"children":[{"identifier":"SERVER_SECURITY","namespace":"HTTP","internal":false,"children":[{"identifier":"BASIC_AUTHENTICATION","namespace":"HTTP","internal":false,"children":[]}]},{"identifier":"NOT_PERMITTED","namespace":"MULE","internal":false,"children":[]}]},{"identifier":"SECURITY","namespace":"HTTP","internal":false,"children":[]},{"identifier":"CLIENT_SECURITY","namespace":"MULE","internal":false,"children":[{"identifier":"CLIENT_SECURITY","namespace":"HTTP","internal":false,"children":[{"identifier":"FORBIDDEN","namespace":"HTTP","internal":false,"children":[]},{"identifier":"UNAUTHORIZED","namespace":"HTTP","internal":false,"children":[]}]}]}]},{"identifier":"NOT_FOUND","namespace":"HTTP","internal":false,"children":[]},{"identifier":"BAD_SQL_SYNTAX","namespace":"DB","internal":false,"children":[]},{"identifier":"SOURCE","namespace":"MULE","internal":true,"children":[{"identifier":"SOURCE_RESPONSE","namespace":"MULE","internal":false,"children":[{"identifier":"SOURCE_RESPONSE_GENERATE","namespace":"MULE","internal":false,"children":[]},{"identifier":"SOURCE_RESPONSE_SEND","namespace":"MULE","internal":false,"children":[]}]},{"identifier":"SOURCE_ERROR_RESPONSE_GENERATE","namespace":"MULE","internal":true,"children":[]},{"identifier":"SOURCE_ERROR_RESPONSE_SEND","namespace":"MULE","internal":true,"children":[]}]},{"identifier":"UNKNOWN","namespace":"MULE","internal":true,"children":[]}]},{"identifier":"CRITICAL","namespace":"MULE","internal":true,"children":[{"identifier":"FATAL_JVM_ERROR","namespace":"MULE","internal":true,"children":[]},{"identifier":"OVERLOAD","namespace":"MULE","internal":true,"children":[{"identifier":"FLOW_BACK_PRESSURE","namespace":"MULE","internal":true,"children":[]}]},{"identifier":"CANCELLED","namespace":"MULE","internal":true,"children":[]}]}]},"importedResources":[]}