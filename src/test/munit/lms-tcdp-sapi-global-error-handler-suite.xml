	<munit:config name="tcdp-global-error-handler-test-suite.xml" />

	<!--
		STRATEGY: lms-tcdp-sapi-global-error-handler uses on-error-PROPAGATE for ALL error types.
		This means errors bubble up after the handler runs.
		All tests:
		  1. Mock apikit:router inside lms-tcdp-sys-api-main to throw the target error.
		  2. Set expectedErrorType on the munit:test so MUnit expects the propagated error.
		  3. The on-error-propagate handler runs (sets payload + httpStatus) then re-throws.
		  4. No validation block needed — expectedErrorType is the assertion.
	-->

